# Frontend
VITE_API_BASE_URL=http://localhost:4000
VITE_GA_MEASUREMENT_ID=
VITE_SUPABASE_URL=https://tafibcweszimipvhytft.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>

# Backend
PORT=4000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
SUPABASE_URL=https://tafibcweszimipvhytft.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
NEXT_PUBLIC_SUPABASE_URL=https://tafibcweszimipvhytft.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>

# Optional split DB vars (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=free_invoice

# Email (SMTP) - required for invoice email delivery
# Using Resend (https://resend.com):
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=onboarding@resend.dev

# BuildOS ERP integration (optional — enables two-way sync)
# Set BUILDOS_API_URL to the running BuildOS backend URL
BUILDOS_API_URL=http://localhost:3001
# A JWT from a BuildOS service-account login (finance-manager or admin role)
BUILDOS_API_TOKEN=
# Must match the secret used when registering the webhook in BuildOS admin
BUILDOS_WEBHOOK_SECRET=
